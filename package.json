{
  "name": "markiplier-dog",
  "version": "1.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next typegen && eslint . && tsc --noEmit",
    "dev": "next dev",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx,mjs,cjs,json,yaml,yml}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx,mjs,cjs,json,yaml,yml}\" --cache",
    "lint": "eslint . --cache",
    "lint:fix": "eslint --fix . --cache",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.61.0",
    "framer-motion": "^12.42.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jiti": "^2.7.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
